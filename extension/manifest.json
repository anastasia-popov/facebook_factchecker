{
  "manifest_version": 3,
  "name": "Fact Checker",
  "version": "1.1",
  "description": "Fact-check text and images on any website with Claude AI or Google Fact Check API.",
  "permissions": ["storage", "contextMenus"],
  "content_security_policy": {
    "script-src": ["'self'", "https://cdn.jsdelivr.net", "https://cdnjs.cloudflare.com"],
    "worker-src": ["'self'", "blob:"]
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["loader_animation.gif"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ]
}
