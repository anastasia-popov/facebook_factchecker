# Google Fact Check Tools API key (required for Google-only fact checking)
# Get free key at: https://console.developers.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Claude API key (required for Claude-based fact checking)
# Get key at: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Serper web search API key (required for Claude fact checking with web search)
# Get free key at: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# ClaimBuster API key (optional)
# If not set, the backend will use simple sentence splitting instead
# Get free key at: https://idir.uta.edu/claimbuster/
CLAIMBUSTER_API_KEY=your_claimbuster_key_here
