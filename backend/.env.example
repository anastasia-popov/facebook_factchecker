# Existing API Keys
GOOGLE_API_KEY=your_google_api_key
CLAUDE_API_KEY=your_claude_api_key
SERPER_API_KEY=your_serper_api_key
CLAIMBUSTER_API_KEY=your_claimbuster_api_key

# OAuth Configuration (GitHub)
# 1. Create GitHub OAuth App at: https://github.com/settings/developers/oauth-apps/new
#    - Authorization callback URL: http://localhost:8000/auth/callback
# 2. Get Client ID and Client Secret from the app settings
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

# JWT Configuration
# Generate a random secret key (at least 32 characters):
# Python: import secrets; print(secrets.token_urlsafe(32))
JWT_SECRET_KEY=your_random_secret_key_here

# JWT Token Settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Database
DATABASE_URL=sqlite:///./factchecker.db

# Backend URL (used for OAuth redirects)
BACKEND_URL=http://localhost:8000
