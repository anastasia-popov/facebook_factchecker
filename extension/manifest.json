{
  "manifest_version": 3,
  "name": "Fact Checker",
  "version": "1.1",
  "description": "Fact-check text and images on any website with Claude AI or Google Fact Check API.",
  "permissions": ["storage", "contextMenus"],
  "web_accessible_resources": [
    {
      "resources": ["tesseract-core.wasm.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
