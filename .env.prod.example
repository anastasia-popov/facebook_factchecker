# Production Environment Configuration for Gold Server
# Copy this file to .env.prod and fill in your actual values
# DO NOT commit .env.prod to version control!

# ==================== API Keys ====================
GOOGLE_API_KEY=your_google_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
SERPER_API_KEY=your_serper_api_key_here
CLAIMBUSTER_API_KEY=your_claimbuster_api_key_here

# ==================== OAuth Configuration ====================
# Create Google OAuth App at: https://console.cloud.google.com/apis/credentials
# For production, update redirect URI to: https://your-domain.com/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# ==================== JWT Configuration ====================
# Generate a random secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_random_secret_key_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=30

# ==================== Database ====================
# PostgreSQL (recommended for production)
# Using docker-compose: db service hostname is "db", default port is 5432
POSTGRES_DB=factchecker
POSTGRES_USER=factchecker
POSTGRES_PASSWORD=change_me_to_secure_password
DATABASE_URL=postgresql://factchecker:change_me_to_secure_password@db:5432/factchecker

# For development, uncomment to use SQLite instead:
# DATABASE_URL=sqlite:///./factchecker.db

# ==================== Backend URL ====================
# This should be your production domain
# Used for OAuth redirects and CORS
BACKEND_URL=https://api.your-domain.com
