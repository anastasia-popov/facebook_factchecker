{
  "manifest_version": 3,
  "name": "Fact Checker",
  "version": "1.1",
  "description": "Fact-check text and images on any website with Claude AI.",
  "browser_specific_settings": {
    "gecko": {
      "id": "factchecker@example.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["contextMenus"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html"
  }
}
