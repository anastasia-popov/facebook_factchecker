{
  "manifest_version": 3,
  "name": "Fact Checker",
  "version": "1.1",
  "description": "Fact-check text and images on any website with Claude AI.",
  "permissions": ["contextMenus", "storage"],
  "content_security_policy": {
    "script-src": ["'self'"],
    "worker-src": ["'self'"]
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
